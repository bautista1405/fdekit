# Provider; use mock, localOllama, openai, anthropic, or google
FDEKIT_PROVIDER=mock

# Optional model override; defaults are provider-specific
FDEKIT_MODEL=

# OpenAI API key used when FDEKIT_PROVIDER=openai
OPENAI_API_KEY=

# Anthropic API key used when FDEKIT_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Google Gemini API key used when FDEKIT_PROVIDER=google
GEMINI_API_KEY=

# Advanced Ollama URL override used when FDEKIT_PROVIDER=localOllama
OLLAMA_BASE_URL=

# Repository to inspect; use .. when the FDEKit project lives in ./fdekit
CODEBASE_ROOT=./sample-repo

# Issue tracker backing issue.create; use github, jira, or linear
FDEKIT_ISSUE_TRACKER=github

# Set to api to create real external issues
FDEKIT_CONNECTOR_MODE=local

# GitHub token for API mode issue creation
GITHUB_TOKEN=

# GitHub repository for codebase findings
GITHUB_REPOSITORY=owner/repo

# Jira Cloud site URL for API mode
JIRA_BASE_URL=https://your-domain.atlassian.net

# Jira account email for API token authentication
JIRA_EMAIL=

# Jira API token for API mode issue creation
JIRA_API_TOKEN=

# Jira project key for codebase findings
JIRA_PROJECT_KEY=ENG

# Linear API key for API mode issue creation
LINEAR_API_KEY=

# Linear team UUID for codebase findings
LINEAR_TEAM_ID=
