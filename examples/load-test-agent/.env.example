# Provider; use mock, localOllama, openai, anthropic, or google
FDEKIT_PROVIDER=mock

# Optional model override; defaults are provider-specific
FDEKIT_MODEL=

# OpenAI API key used when FDEKIT_PROVIDER=openai
OPENAI_API_KEY=

# Anthropic API key used when FDEKIT_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Google Gemini API key used when FDEKIT_PROVIDER=google
GEMINI_API_KEY=

# Advanced Ollama URL override used when FDEKIT_PROVIDER=localOllama
OLLAMA_BASE_URL=

# Use local for a deterministic no-HTTP simulation or k6 for measured execution
FDEKIT_LOAD_TEST_MODE=local

# Customer API base URL for load testing
LOAD_TEST_TARGET_URL=http://localhost:8000

# k6 command or binary path used when FDEKIT_LOAD_TEST_MODE=k6
K6_BINARY=k6

# k6 JavaScript test file
K6_SCRIPT=./load-tests/customer-api-smoke.js

# Default virtual users for the load-test tool
K6_DEFAULT_VUS=5

# Default load-test duration
K6_DEFAULT_DURATION=10s

# Safety cap for virtual users requested by the agent
K6_MAX_VUS=50

# Safety cap for load-test duration requested by the agent
K6_MAX_DURATION_SECONDS=300

# p95 latency threshold used in FDEKit results
K6_P95_THRESHOLD_MS=500

# Allowed request error rate used in FDEKit results
K6_ERROR_RATE_THRESHOLD=0.01
