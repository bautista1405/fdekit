{
  "name": "@fdekit/example-load-test-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Load-test agent example deployment for FDEKit",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "api": "node customer-api/server.js",
    "demo": "node scripts/demo.mjs",
    "fdekit:dev": "fdekit dev",
    "fdekit:doctor": "fdekit doctor",
    "fdekit:eval": "fdekit eval run",
    "fdekit:macro": "fdekit eval macro",
    "fdekit:run": "fdekit run loadTestAgent --input '{\"scenario\":\"smoke\",\"vus\":5,\"duration\":\"10s\"}'",
    "fdekit:approvals": "fdekit approvals list",
    "fdekit:audit": "fdekit audit",
    "fdekit:feedback": "fdekit feedback export",
    "fdekit:validate": "fdekit validate",
    "fdekit:validate:strict": "fdekit validate --strict",
    "fdekit:diff": "fdekit diff",
    "fdekit:trace": "fdekit trace",
    "fdekit:console": "fdekit console",
    "fdekit:report": "fdekit report"
  },
  "dependencies": {
    "@fdekit/connector-k6": "0.4.3",
    "@fdekit/core": "0.4.3"
  },
  "devDependencies": {
    "@fdekit/cli": "0.4.3"
  }
}
