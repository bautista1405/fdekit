# Provider; use mock, localOllama, openai, anthropic, or google
FDEKIT_PROVIDER=mock

# Optional model override; defaults are provider-specific
FDEKIT_MODEL=

# OpenAI API key used when FDEKIT_PROVIDER=openai
OPENAI_API_KEY=

# Anthropic API key used when FDEKIT_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Google Gemini API key used when FDEKIT_PROVIDER=google
GEMINI_API_KEY=

# Advanced Ollama URL override used when FDEKIT_PROVIDER=localOllama
OLLAMA_BASE_URL=

# CRM backend for crm.note.create; use local, hubspot, or salesforce
FDEKIT_CRM=local

# Set to api to turn the selected CRM connector into live API mode
FDEKIT_CONNECTOR_MODE=local

# Local sales research dataset; replace with a customer CRM export for the first demo rung
SALES_RESEARCH_DATASET=./sales-data/prospects.json

# HubSpot private app token used when FDEKIT_CRM=hubspot and FDEKIT_CONNECTOR_MODE=api
HUBSPOT_ACCESS_TOKEN=

# Optional HubSpot portal id used to build note links
HUBSPOT_PORTAL_ID=

# Salesforce instance URL used when FDEKIT_CRM=salesforce and FDEKIT_CONNECTOR_MODE=api
SALESFORCE_INSTANCE_URL=https://your-domain.my.salesforce.com

# Salesforce OAuth access token used when FDEKIT_CRM=salesforce and FDEKIT_CONNECTOR_MODE=api
SALESFORCE_ACCESS_TOKEN=

# Optional Salesforce REST API version override
SALESFORCE_API_VERSION=v60.0

# Optional default Salesforce Account/Opportunity id for CRM notes
SALESFORCE_ACCOUNT_ID=
