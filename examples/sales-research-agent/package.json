{
  "name": "@fdekit/example-sales-research-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Sales research agent example deployment for FDEKit",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "demo": "node scripts/demo.mjs",
