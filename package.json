    "example:sales:report": "npm run fdekit:report -w @fdekit/example-sales-research-agent",
    "example:sales:run": "npm run fdekit:run -w @fdekit/example-sales-research-agent",
    "example:sales:approvals": "npm run fdekit:approvals -w @fdekit/example-sales-research-agent",
    "example:sales:audit": "npm run fdekit:audit -w @fdekit/example-sales-research-agent",
    "example:sales:feedback": "npm run fdekit:feedback -w @fdekit/example-sales-research-agent",
    "example:sales:validate": "npm run fdekit:validate -w @fdekit/example-sales-research-agent",
    "example:sales:diff": "npm run fdekit:diff -w @fdekit/example-sales-research-agent",
    "example:loadtest:api": "npm run api -w @fdekit/example-load-test-agent",
    "example:loadtest:demo": "npm run demo -w @fdekit/example-load-test-agent",
    "example:loadtest:console": "npm run fdekit:console -w @fdekit/example-load-test-agent",
    "example:loadtest:dev": "npm run fdekit:dev -w @fdekit/example-load-test-agent",
    "example:loadtest:doctor": "npm run fdekit:doctor -w @fdekit/example-load-test-agent",
