{
  "name": "fdekit-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "packages/*",
    "packages/providers/*",
    "packages/connectors/*",
    "packages/environments/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=fdekit",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test -- --watch",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "npm run build && changeset publish",
    "docs:catalog": "npm run build && node scripts/generate-catalog-docs.mjs",
    "docs:api": "npm run build && node scripts/generate-api-docs.mjs",
    "examples:check": "node scripts/check-recipe-examples.mjs",
    "examples:sync": "node scripts/check-recipe-examples.mjs --write",
    "connectors:smoke:live": "node scripts/live-connector-smoke.mjs",
    "demo": "node scripts/demo.mjs",
    "demo:fast": "node scripts/demo.mjs --skip-build",
    "example:api": "npm run api -w @fdekit/example-support-triage",
    "example:support:demo": "npm run demo -w @fdekit/example-support-triage",
    "example:codebase:demo": "npm run demo -w @fdekit/example-codebase-agent",
    "example:codebase:console": "npm run fdekit:console -w @fdekit/example-codebase-agent",
    "example:codebase:dev": "npm run fdekit:dev -w @fdekit/example-codebase-agent",
    "example:codebase:doctor": "npm run fdekit:doctor -w @fdekit/example-codebase-agent",
    "example:codebase:eval": "npm run fdekit:eval -w @fdekit/example-codebase-agent",
    "example:codebase:macro": "npm run fdekit:macro -w @fdekit/example-codebase-agent",
    "example:codebase:report": "npm run fdekit:report -w @fdekit/example-codebase-agent",
    "example:codebase:run": "npm run fdekit:run -w @fdekit/example-codebase-agent",
    "example:codebase:approvals": "npm run fdekit:approvals -w @fdekit/example-codebase-agent",
    "example:codebase:audit": "npm run fdekit:audit -w @fdekit/example-codebase-agent",
    "example:codebase:feedback": "npm run fdekit:feedback -w @fdekit/example-codebase-agent",
    "example:codebase:validate": "npm run fdekit:validate -w @fdekit/example-codebase-agent",
    "example:codebase:diff": "npm run fdekit:diff -w @fdekit/example-codebase-agent",
    "example:sales:console": "npm run fdekit:console -w @fdekit/example-sales-research-agent",
    "example:sales:demo": "npm run demo -w @fdekit/example-sales-research-agent",
    "example:sales:dev": "npm run fdekit:dev -w @fdekit/example-sales-research-agent",
    "example:sales:doctor": "npm run fdekit:doctor -w @fdekit/example-sales-research-agent",
    "example:sales:eval": "npm run fdekit:eval -w @fdekit/example-sales-research-agent",
