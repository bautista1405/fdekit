{
  "name": "@fdekit/cli",
  "version": "0.4.7",
  "description": "Command line interface for FDEKit",
  "license": "MIT",
  "bin": {
    "fdekit": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run clean && tsc -p . && node scripts/copy-recipe-assets.mjs && node -e \"fs.chmodSync('dist/index.js', 0o755)\"",
    "dev": "node dist/index.js",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fdekit/console": "0.4.7",
    "@fdekit/core": "0.4.7",
    "@fdekit/provider-anthropic": "0.4.7",
    "@fdekit/provider-google": "0.4.7",
    "@fdekit/provider-ollama": "0.4.7",
    "@fdekit/provider-openai": "0.4.7",
    "@fdekit/runtime": "0.4.7",
    "typescript": "^5.4.5"
  },
  "devDependencies": {},
  "type": "module"
}
